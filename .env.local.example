# Supabase（必填）：在 Supabase Dashboard → Project Settings → API 查看
NEXT_PUBLIC_SUPABASE_URL=https://qwmtbgakntjtgdudwqnw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_mcqvkmyCYaV4KhBhh_StRg_UqDrNXEe   # 服务端用 service_role，不要暴露到前端

# 大模型（分析新闻用）：三选一，不填则信号为默认值
# 推荐 火山引擎豆包（国内、有免费额度）：https://console.volcengine.com/ark → 在线推理 → 获取 API Key
# VOLCENGINE_API_KEY=你的API_Key
# 预置接入点可直接用模型 ID；自定义接入点用 ep-xxx
# VOLCENGINE_ENDPOINT_ID=doubao-seed-2-0-lite-260215
# 或 VOLCENGINE_ENDPOINT_ID=ep-xxxxxxxx

# 或 DeepSeek：https://platform.deepseek.com 获取 API Key
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat   # 可选

# 或 OpenAI（需能访问 api.openai.com）
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=   # 可选，代理时填镜像地址

# 可选：信号强度≥此值记入提醒，默认 70
ALERT_STRENGTH_THRESHOLD=70

# 静态部署时：API 由边缘函数提供，填边缘函数站点地址（末尾不要 /）
# NEXT_PUBLIC_API_URL=https://your-api-worker.xxx.workers.dev

# 可选：提醒邮件（需 SMTP，如 QQ 邮箱）。群发多个邮箱用逗号分隔
# EMAIL_USER=your@qq.com
# EMAIL_PASS=授权码
# EMAIL_TO=one@example.com,two@example.com
